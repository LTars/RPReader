{
  "authors": [
    {
      "id": "tars",
      "names": ["Tars"],
      "defaultSide": "right",
      "color": "#c084fc"
    },
    {
      "id": "zaveta",
      "names": ["zaveta-Даша", "zaveta", "zavet", "Даша"],
      "defaultSide": "left",
      "color": "#67e8f9"
    }
  ],
  "patterns": [
    {
      "name": "author_block",
      "description": "Строка вида [Имя] или [Имя дата время]",
      "regex": "^\\[([^\\]]+?)(?:\\s+(\\d{1,2}/\\d{1,2}/\\d{4}\\s+\\d{1,2}:\\d{2}(?::\\d{2})?(?:\\s+[AP]M)?))?\\]\\s*$",
      "groups": { "author": 1, "datetime": 2 },
      "handler": "authorBlock"
    },
    {
      "name": "star_divider",
      "description": "Строка только из звёздочек — разделитель сцены",
      "regex": "^\\*+$",
      "handler": "starDivider"
    },
    {
      "name": "dialogue_line",
      "description": "Реплика начинается с тире",
      "regex": "^[-–—]",
      "handler": "dialogueLine"
    }
  ],
  "transforms": [
    {
      "name": "normalize_zaveta",
      "description": "zaveta → zaveta-Даша везде кроме заголовков",
      "find": "\\bzaveta\\b",
      "replace": "zaveta-Даша",
      "flags": "g"
    }
  ],
  "cleanup": {
    "stripDateLines": true,
    "collapseMultipleNewlines": true,
    "maxConsecutiveNewlines": 2
  }
}
